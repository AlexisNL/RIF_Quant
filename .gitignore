# ============================================================================
# RIF — Regime Identification Framework
# ============================================================================

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
env/
venv/
ENV/
.venv/
.ENV/

# Distribution / packaging
build/
develop-eggs/
dist/
*.egg-info/
*.egg
MANIFEST

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.pytest_cache/

# ============================================================================
# JUPYTER NOTEBOOKS
# ============================================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================================
# LATEX — auxiliary files
# ============================================================================
*.aux
*.bbl
*.bcf
*.blg
*.log
*.out
*.run.xml
*.synctex.gz
*.synctex(busy)
*.fdb_latexmk
*.fls
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
*.brf
*.idx
*.ilg
*.ind
texput.log

# ============================================================================
# DONNÉES
# ============================================================================
# Données brutes LOBSTER (propriétaires, non redistribuables)
data/raw/*.csv
data/raw/*.h5
data/raw/*.hdf5
data/raw/*.parquet

# Données traitées et résultats générés
data/processed/*.csv
data/processed/*.h5
data/processed/*.parquet
data/results/*
!data/results/.gitkeep

# Caches numériques
*.pkl
*.pickle

# ============================================================================
# FICHIERS GÉNÉRÉS (figures, tables, PDFs)
# ============================================================================
*.png
*.jpg
*.jpeg
*.pdf
*.svg

paper/figures/*
!paper/figures/.gitkeep

paper/tables/*
!paper/tables/.gitkeep

paper/supplementary/*
!paper/supplementary/.gitkeep

img/

# ============================================================================
# DOCUMENTS (paper source — not needed to run the code)
# ============================================================================
paper/main.tex
paper/main.pdf
paper_revised.*
paper.tex

# Submission files
soumission QF/

# ============================================================================
# FICHIERS SYSTÈME
# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
NUL

# ============================================================================
# IDE & ÉDITEURS
# ============================================================================
.vscode/
*.code-workspace
.idea/
*.swp
*.swo
*~

# Claude IDE config
.claude/

# GitHub Pages (not part of the code)
_config.yml
index.md

# ============================================================================
# DIVERS
# ============================================================================
*.tmp
*.bak
*.backup
~$*
logs/
poetry.lock
